<robot name="bonetag_tibia">
    <link name="tibia_base_link" />
    <link name="support_tibia">
        <inertial>
            <origin xyz="0 0 0.09"/>
            <mass value="0.05"/>
            <inertia ixx="-0.00026875" ixy="0" ixz="0" iyy="-0.00026875" iyz="0" izz="4.2e-07"/>
        </inertial>
        <visual>
            <geometry>
                <mesh filename="file://@MODULE_INSTALL_LOCATION@/meshes/bonetag_tibia/support_tibia.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="file://@MODULE_INSTALL_LOCATION@/meshes/bonetag_tibia/support_tibia.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>
    <link name="tibia">
        <inertial>
            <origin xyz="0.0017 -0.0008 -0.00714"/>
            <mass value="0.1703"/>
            <inertia ixx="3.92365e-05" ixy="-1.20287e-06" ixz="-2.37101e-06" iyy="8.74767e-05" iyz="1.46109e-06" izz="0.000103691"/>
        </inertial>
        <visual>
            <geometry>
                <mesh filename="file://@MODULE_INSTALL_LOCATION@/meshes/bonetag_tibia/tibia.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="file://@MODULE_INSTALL_LOCATION@/meshes/bonetag_tibia/tibia.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>
    <joint name="ee_to_support" type="fixed">
        <parent link="tibia_base_link"/>
        <child link="support_tibia"/>
        <origin xyz="0 0 0.145" rpy="0 1.57 0"/>
    </joint>
    <joint name="support_to_prosthesis" type="fixed">
        <parent link="support_tibia"/>
        <child link="tibia"/>
        <origin xyz="-0.05 0.035 0.045" rpy="-1.57 1.57 0"/>
    </joint>
</robot>
