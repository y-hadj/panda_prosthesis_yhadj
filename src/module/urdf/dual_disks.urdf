<?xml version="1.0" ?>
<robot name="dual_disks">
  <link name="world"/>

  <link name="disk1">
    <visual>
      <origin xyz="0 0 -0.065" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.2"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.065" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.2"/>
      </geometry>
    </collision>
  </link>

  <link name="disk2">
    <visual>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 0.5"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.2"/>
      </geometry>
    </collision>
  </link>

  <joint name="world_to_disk1" type="fixed">
    <parent link="world"/>
    <child link="disk1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="world_to_disk2" type="fixed">
    <parent link="world"/>
    <child link="disk2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
